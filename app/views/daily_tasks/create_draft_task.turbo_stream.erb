<%= turbo_stream.append "draft_tasks" do %>
  <%= form_with model: DailyTask.new, class: "form mt-3 pr-2" do |form| %>
    <div class="field">
      <%= form.text_field :title, class: "input", placeholder: "Enter title" %>
    </div>
    <div class="field">
      <div class="select">
        <%= form.select :smart_goal_id, options_from_collection_for_select(@user.smart_goals, :id, :measurable_goal) %>
      </div>
    </div>
  <% end %>
<% end %>